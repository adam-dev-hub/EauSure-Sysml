@startuml EauSure_UC01_User

top to bottom direction

skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam actorStyle awesome
skinparam usecaseBorderColor #2C7BB6
skinparam usecaseBackgroundColor #EAF4FB
skinparam usecaseBorderThickness 1.5
skinparam ArrowColor #444444
skinparam ArrowFontSize 10
skinparam actorBackgroundColor #FFF8E7
skinparam actorBorderColor #E69500
skinparam shadowing false
skinparam ranksep 35
skinparam nodesep 20
skinparam rectangleFontAlign left


actor "Utilisateur" as User

rectangle "[uc_01] Système EauSûre - Vue Utilisateur" {

  ' ── Groupe 1 — Dashboard
  usecase "Accéder au\ntableau de bord"                 as UC_Dashboard
  usecase "Superviser les métriques\nen temps réel"     as UC_Realtime
  usecase "Consulter l'historique\net les statistiques" as UC_HistoryStats
  usecase "Consulter les alertes"                        as UC_ViewAlerts

  ' ── Groupe 2 — Hardware
  usecase "Gérer le hardware"                        as UC_HardwareMgmt
  usecase "Mettre en service\nla passerelle"         as UC_RegisterGateway
  usecase "Jumeler le noeud\nde mesurage"            as UC_PairNode
  usecase "Consulter l'état\nde fonctionnement"      as UC_HealthStatus

  ' ── Groupe 3 — Configuration
  usecase "Configurer le système"                    as UC_ConfigSystem
  usecase "Définir les seuils\nde qualité d'eau"     as UC_SetThresholds
  usecase "Activer/désactiver\nles alertes locales"  as UC_LocalAlerts
  usecase "Régler la fréquence\nde suivi d'état"      as UC_HealthFreq
  usecase "Régler la fréquence\nde télémétrie"       as UC_TelemetryFreq
  usecase "Activer/désactiver\nl'anti-chute"         as UC_AntiFall

  ' ── Groupe 4 — Mises à jour
  usecase "Gérer les mises à jour"                   as UC_UserUpdateMgmt
  usecase "Rechercher les mises\nà jour disponibles" as UC_CheckUpdates
  usecase "Lancer le processus\nde mise à jour"      as UC_StartUpdate

  ' ── Groupe 5 — Assistance
  usecase "Demander de\n l'assistance technique"                     as UC_TechSupport
  usecase "Réclamer un bug ou\nun problème technique" as UC_ReportIssue
  usecase "Communiquer avec\nun administrateur"      as UC_ContactAdmin
}

' ── Associations acteur (parents uniquement)
User --> UC_Dashboard
User --> UC_HardwareMgmt
User --> UC_ConfigSystem
User --> UC_UserUpdateMgmt
User --> UC_TechSupport

' ── Dashboard
UC_Dashboard  <.. UC_Realtime    : <<extend>>
UC_HistoryStats ..> UC_Dashboard : <<extend>>
UC_ViewAlerts   ..> UC_Dashboard : <<extend>>

' ── Hardware
UC_RegisterGateway ..> UC_HardwareMgmt : <<extend>>
UC_PairNode        ..> UC_HardwareMgmt : <<extend>>
UC_PairNode        ..> UC_RegisterGateway : <<include>>
UC_HealthStatus    ..> UC_HardwareMgmt : <<extend>>

' ── Configuration
UC_SetThresholds ..> UC_ConfigSystem : <<extend>>
UC_LocalAlerts   ..> UC_ConfigSystem : <<extend>>
UC_HealthFreq    ..> UC_ConfigSystem : <<extend>>
UC_TelemetryFreq ..> UC_ConfigSystem : <<extend>>
UC_AntiFall      ..> UC_ConfigSystem : <<extend>>

' ── Mises à jour
UC_CheckUpdates ..> UC_UserUpdateMgmt : <<extend>>
UC_StartUpdate  ..> UC_UserUpdateMgmt : <<extend>>
UC_StartUpdate  ..> UC_CheckUpdates   : <<include>>

' ── Assistance
UC_ReportIssue  ..> UC_TechSupport : <<extend>>
UC_ContactAdmin ..> UC_TechSupport : <<extend>>

' ══════════════════════════════════════════════
' LAYOUT
' ══════════════════════════════════════════════

' Colonne parents
UC_Dashboard      -[hidden]down- UC_HardwareMgmt
UC_HardwareMgmt   -[hidden]down- UC_ConfigSystem
UC_ConfigSystem   -[hidden]down- UC_UserUpdateMgmt
UC_UserUpdateMgmt -[hidden]down- UC_TechSupport

' Bande 1
UC_Dashboard    -[hidden]right- UC_Realtime
UC_Realtime     -[hidden]right- UC_HistoryStats
UC_HistoryStats -[hidden]right- UC_ViewAlerts

' Bande 2
UC_HardwareMgmt    -[hidden]right- UC_RegisterGateway
UC_RegisterGateway -[hidden]right- UC_PairNode
UC_PairNode        -[hidden]right- UC_HealthStatus

' Bande 3
UC_ConfigSystem  -[hidden]right- UC_SetThresholds
UC_SetThresholds -[hidden]right- UC_LocalAlerts
UC_LocalAlerts   -[hidden]right- UC_HealthFreq
UC_HealthFreq    -[hidden]right- UC_TelemetryFreq
UC_TelemetryFreq -[hidden]right- UC_AntiFall

' Bande 4
UC_UserUpdateMgmt -[hidden]right- UC_CheckUpdates
UC_CheckUpdates   -[hidden]right- UC_StartUpdate

' Bande 5
UC_TechSupport -[hidden]right- UC_ReportIssue
UC_ReportIssue -[hidden]right- UC_ContactAdmin

@enduml
