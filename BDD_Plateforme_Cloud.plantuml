@startuml BDD_Plateforme_Cloud

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam classBackgroundColor #F3E5F5
skinparam classBorderColor #7B1FA2
skinparam classBorderThickness 1.5
skinparam ArrowColor #2C3E50
skinparam shadowing false
skinparam packageBackgroundColor #EDE7F6
skinparam packageBorderColor #4A4A6A
skinparam packageBorderThickness 1.5
skinparam packageFontStyle bold
skinparam packageFontSize 11
skinparam classAttributeFontSize 10
skinparam classHeaderBackgroundColor #D1C4E9
skinparam classStereotypeFontSize 10
skinparam minClassWidth 220
skinparam roundCorner 8

hide empty members

title <b>Diagramme de Définition de Blocs - Plateforme cloud</b>\n<i>Décomposition fonctionnelle interne - Système EauSûre</i>

class "Plateforme cloud" <<block>>

package "Fonctions internes" #EDE7F6 {

  class "Gestion des données" <<block>> {
    + stocker les mesures reçues
    + assurer la rétention et l'archivage
  }

  class "Analyse et traitement" <<block>> {
    + traiter les données en temps réel
    + détecter les tendances et anomalies
  }

  class "Gestion des alertes" <<block>> {
    + évaluer les seuils de qualité de l'eau
    + déclencher et router les notifications
  }

  class "Authentification et sécurité" <<block>> {
    + contrôler les accès utilisateurs
    + garantir la confidentialité des données
  }

  class "Interface API" <<block>> {
    + exposer les données aux applications
    + recevoir les requêtes des clients
  }

  "Gestion des données"        -[hidden]down- "Analyse et traitement"
  "Analyse et traitement"      -[hidden]down- "Gestion des alertes"
  "Gestion des alertes"        -[hidden]down- "Authentification et sécurité"
  "Authentification et sécurité" -[hidden]down- "Interface API"

}

"Plateforme cloud" *-down- "Gestion des données"
"Plateforme cloud" *-down- "Analyse et traitement"
"Plateforme cloud" *-down- "Gestion des alertes"
"Plateforme cloud" *-down- "Authentification et sécurité"
"Plateforme cloud" *-down- "Interface API"

@enduml