@startuml BDD_Global

skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam classBackgroundColor #EAF4FB
skinparam classBorderColor #2C7BB6
skinparam classBorderThickness 1.5
skinparam ArrowColor #2C3E50
skinparam shadowing false
skinparam packageBackgroundColor #F0F4FF
skinparam packageBorderColor #4A4A6A
skinparam packageBorderThickness 1.5
skinparam packageFontStyle bold
skinparam packageFontSize 12
skinparam classAttributeFontSize 11
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #E0A500

hide empty members

title <b>Diagramme de Définition de Blocs - Vue Globale</b>\n<i>Système EauSûre - Surveillance de la qualité de l'eau en milieu rural</i>

package "Système EauSûre" #DDEEFF {

  class "EauSûre" <<system>> {
  }

  class "Nœud de mesure" <<block>> {
    + collecte de données environnementales
    + transmission périodique des mesures
  }

  class "Passerelle de communication" <<block>> {
    + relais des données vers le cloud
    + gestion de la connectivité réseau
  }

  class "Plateforme cloud" <<block>> {
    + traitement et stockage des données
    + génération des alertes
  }

}

class "Application utilisateur" <<external>> {
  + visualisation des données
  + réception des notifications
}

"EauSûre" "1" *-down- "1..*" "Nœud de mesure"
"EauSûre" "1" *-down- "1..*" "Passerelle de communication"
"EauSûre" "1" *-down- "1"    "Plateforme cloud"

"Plateforme cloud" ..> "Application utilisateur" : <<use>>


@enduml