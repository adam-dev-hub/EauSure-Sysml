@startuml EauSure_UseCase_Diagram_v3

skinparam defaultFontName Arial
skinparam defaultFontSize 13
skinparam actorStyle awesome
skinparam usecaseBorderColor #2C7BB6
skinparam usecaseBackgroundColor #EAF4FB
skinparam usecaseBorderThickness 1.5
skinparam packageBorderColor #555555
skinparam packageBackgroundColor #FAFAFA
skinparam packageBorderThickness 1.5
skinparam ArrowColor #444444
skinparam actorBackgroundColor #FFF8E7
skinparam actorBorderColor #E69500
skinparam shadowing false

title <b>Diagramme de Cas d'Utilisation — Système EauSûre v3</b>\n<i>Bouée IoT de Surveillance de Qualité d'Eau</i>

' ─────────────────────────────────────────
'  ACTEURS (uniquement acteurs métier externes)
' ─────────────────────────────────────────
actor "Utilisateur"    as User
actor "Administrateur" as Admin

' ─────────────────────────────────────────
'  FRONTIÈRE SYSTÈME
' ─────────────────────────────────────────
rectangle "Système EauSûre" {

  ' ── PACKAGE 1 : Mise en service ──
  package "Mise en service" {
    usecase "Initialiser\nle système"                       as UC_Init
    usecase "Connecter automatiquement\nIoT ↔ Passerelle"  as UC_Connect
  }

  ' ── PACKAGE 2 : Utilisation ──
  package "Utilisation" {
    usecase "Se connecter\nau système"                      as UC_Auth
    usecase "Consulter les données"                         as UC_Consult
    usecase "Visualiser le dashboard"                       as UC_Dashboard
    usecase "Consulter l'historique"                        as UC_History
    usecase "Recevoir des alertes"                          as UC_Alert
    usecase "Recevoir une alerte\nde chute"                 as UC_AlertFall
    usecase "Recevoir une alerte de\ndégradation de\nla qualité de l'eau" as UC_AlertQuality
  }

  ' ── PACKAGE 3 : Maintenance ──
  package "Maintenance" {
    usecase "Mettre à jour\nle système (FUOTA)"             as UC_FUOTA
    usecase "Valider une\nmise à jour"                      as UC_ValidUpdate
  }

  ' ── PACKAGE 4 : Administration ──
  package "Administration" {
    usecase "Gérer les utilisateurs"                        as UC_ManageUsers
    usecase "Superviser le système"                         as UC_Supervise
    usecase "Déployer les\nmises à jour"                    as UC_Deploy
    usecase "Diagnostiquer\nun problème"                    as UC_Diag
  }

}

' ─────────────────────────────────────────
'  ASSOCIATIONS ACTEURS → USE CASES
' ─────────────────────────────────────────

' Utilisateur
User  --> UC_Init
User  --> UC_Auth
User  --> UC_Consult
User  --> UC_Alert
User  --> UC_FUOTA

' Administrateur
Admin --> UC_ManageUsers
Admin --> UC_Supervise
Admin --> UC_Deploy
Admin --> UC_Diag

' ─────────────────────────────────────────
'  RELATIONS <<include>>
' ─────────────────────────────────────────

' Initialisation → connexion automatique (obligatoire)
UC_Init    ..> UC_Connect     : <<include>>

' Consultation → sous-fonctions obligatoires
UC_Consult ..> UC_Dashboard   : <<include>>
UC_Consult ..> UC_History     : <<include>>

' Déploiement → mise à jour puis validation (obligatoires)
UC_Deploy  ..> UC_FUOTA       : <<include>>
UC_FUOTA   ..> UC_ValidUpdate : <<include>>

' ─────────────────────────────────────────
'  RELATIONS <<extend>>
' ─────────────────────────────────────────

' Alertes conditionnelles
UC_Alert ..> UC_AlertFall     : <<extend>>
UC_Alert ..> UC_AlertQuality  : <<extend>>

@enduml